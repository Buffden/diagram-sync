{
  "name": "diagram-sync",
  "version": "3.5.0",
  "description": "Automatically export diagrams from PlantUML, Mermaid, Graphviz, Draw.io, D2, Excalidraw, and BPMN source files — keeps architecture documentation in sync with code across CI/CD pipelines, npm scripts, and local workflows.",
  "bin": {
    "diagram-sync": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "keywords": [
    "plantuml",
    "diagram",
    "diagram-sync",
    "architecture",
    "architecture-diagram",
    "documentation-as-code",
    "diagrams-as-code",
    "svg",
    "svg-generator",
    "github-actions",
    "ci-cd",
    "developer-tools",
    "mermaid",
    "graphviz",
    "dot",
    "drawio",
    "draw-io",
    "devops",
    "automation",
    "technical-documentation",
    "mermaid-cli",
    "plantuml-generator",
    "cli-tool",
    "docs-as-code",
    "readme-diagrams",
    "d2",
    "excalidraw",
    "excalidraw-cli",
    "bpmn",
    "bpmn-to-image"
  ],
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "author": {
    "name": "Buffden",
    "url": "https://buffden.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Buffden/diagram-sync.git"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
