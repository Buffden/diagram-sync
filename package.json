{
  "name": "diagram-sync",
  "version": "0.1.0",
  "description": "CLI tool to generate and sync architecture diagrams from source files for README, Wiki, and CI/CD documentation workflows.",
  "bin": {
    "diagram-sync": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "plantuml",
    "diagram",
    "architecture",
    "documentation-as-code",
    "diagrams-as-code",
    "svg",
    "github-actions",
    "ci-cd",
    "developer-tools"
  ],
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "author": {
    "name": "Buffden",
    "url": "https://buffden.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Buffden/diagram-sync.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
