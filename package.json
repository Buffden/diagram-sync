{
  "name": "diagram-sync",
  "version": "2.0.0",
  "description": "Automatically export diagrams from PlantUML and Mermaid source files — keeps architecture documentation in sync with code across CI/CD pipelines, npm scripts, and local workflows.",
  "bin": {
    "diagram-sync": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "plantuml",
    "diagram",
    "diagram-sync",
    "architecture",
    "architecture-diagram",
    "documentation-as-code",
    "diagrams-as-code",
    "svg",
    "svg-generator",
    "github-actions",
    "ci-cd",
    "developer-tools",
    "mermaid",
    "devops",
    "automation",
    "technical-documentation",
    "mermaid-cli",
    "plantuml-generator",
    "cli-tool",
    "docs-as-code",
    "readme-diagrams"
  ],
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "author": {
    "name": "Buffden",
    "url": "https://buffden.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Buffden/diagram-sync.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
